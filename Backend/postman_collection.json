{
  "info": {
    "name": "SetUp API",
    "description": "API Documentation for SetUp Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Student\",\n    \"email\": \"202301010001@mitaoe.ac.in\",\n    \"password\": \"Password123!\",\n    \"phoneNumber\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/auth/register",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"202301010001@mitaoe.ac.in\",\n    \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/auth/login",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"<verification_token>\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/auth/verify-email",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-email"
              ]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"202301010001@mitaoe.ac.in\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/auth/forgot-password",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"token\": \"<reset_token>\",\n    \"password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/auth/reset-password",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "reset-password"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer <token>"
              }
            ],
            "url": {
              "raw": "{{URL}}/api/users/me",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer <token>"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Updated Name\",\n    \"phoneNumber\": \"9876543211\"\n}"
            },
            "url": {
              "raw": "{{URL}}/api/users/me",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "URL",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ]
}
